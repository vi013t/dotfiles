# Ignore everything
*
!.gitignore
!.git
!.git/*
!README.md

# Scripts
!.scripts
!.scripts/*

# Config
!.config
.config/*
!.config/VSCodium
!.config/VSCodium/User
!.config/VSCodium/User/settings.json
!.config/VSCodium/User/README.md
!.config/awesome/
!.config/awesome/**/*
!.config/cfg/
!.config/cfg/**/*
!.config/picom/
!.config/picom/**/*
!.config/nvim
!.config/nvim/**/*
!.config/darling
!.config/darling/**/*
!.config/onedrive
!.config/onedrive/config
!.config/onedrive/README.md
!.config/wezterm
!.config/wezterm/**/*
!.config/joshuto
!.config/joshuto/**/*
!.config/README.md

# Shell RCs
!.bashrc
