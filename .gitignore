# Ignore everything
*
# Except:

# Git
!.gitignore
!.git
!.git/*

# README
!README.md
!.docs/
!.docs/**/*

# Scripts
!.scripts
!.scripts/*

# Config
!.config
.config/*
!.config/README.md

# AwesomeWM
!.config/awesome/
!.config/awesome/**/*

# Cfg
!.config/cfg/
!.config/cfg/**/*

# Darling
!.config/darling
!.config/darling/**/*

# Joshuto
!.config/joshuto
!.config/joshuto/**/*

# Neovim
!.config/nvim
!.config/nvim/**/*

# Onedrive
!.config/onedrive
!.config/onedrive/config
!.config/onedrive/README.md

# Picom
!.config/picom/
!.config/picom/**/*

# VSCodium
!.config/VSCodium
!.config/VSCodium/User
!.config/VSCodium/User/settings.json
!.config/VSCodium/User/README.md

# Wezterm
!.config/wezterm
!.config/wezterm/**/*

# Shell RCs
!.bashrc
